# ======== 服务器配置 / Server ========
SERVER_IP=YOUR_SERVER_IP

# ======== MySQL / EspoCRM ========
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD
ESPO_ADMIN_USER=admin
ESPO_ADMIN_PASSWORD=YOUR_ESPO_ADMIN_PASSWORD
ESPO_API_KEY=YOUR_ESPO_API_KEY

# ======== PostgreSQL / Chatwoot ========
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
CHATWOOT_SECRET=YOUR_CHATWOOT_SECRET
CHATWOOT_API_TOKEN=YOUR_CHATWOOT_API_TOKEN

# ======== AI API ========
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# ======== WeChat 通知 / WeChat Webhook ========
WECHAT_WEBHOOK_URL=YOUR_WECHAT_WEBHOOK_URL

# ======== SMTP 邮件 / Email ========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_SMTP_APP_PASSWORD
